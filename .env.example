# 複製成 .env 後填入。.env 不進版控。

# --- 服務 ---
HOST=0.0.0.0
PORT=8000
# 主埠被占用時依序嘗試(逗號分隔)。用到備用埠要同步改裝置 URL 埠號
FALLBACK_PORTS=8080,8888
# 頁面內建 meta 自動刷新秒數;0 = 關(改由 ADB 控刷新時設 0)
HTML_AUTO_REFRESH_SECONDS=600

# --- 天氣: 中央氣象署 CWA 開放資料 ---
# 申請: https://opendata.cwa.gov.tw/  (授權碼 CWA-xxxx)
CWA_API_KEY=
# 縣市, 例: 臺中市 / 臺北市 / 高雄市
CWA_LOCATION=臺中市

# --- 空氣品質: 環境部 MOENV 開放資料 ---
# 申請: https://data.moenv.gov.tw/  (AQI 資料集 aqx_p_432)
MOENV_API_KEY=
AQI_SITE=斗六
AQI_COUNTY=雲林縣

# --- Steam 狀態(最近遊玩 + 最近成就)---
# 金鑰申請: https://steamcommunity.com/dev/apikey
# STEAM_ID 為 64 位數 SteamID64(個人檔案設「公開」,含遊戲細節與成就)
STEAM_API_KEY=
STEAM_ID=

# --- AI 額度 ---
# Claude: 自動讀 ~/.claude/.credentials.json;或設 CLAUDE_CODE_OAUTH_TOKEN 覆寫
# Codex:  自動讀 ~/.codex/auth.json;或設 CODEX_ACCESS_TOKEN 覆寫
# OpenRouter: 程式與設定預留,目前不註冊收集器
OPENROUTER_API_KEY=

# --- 裝置控制: ADB (HyRead Gaze Note Plus, Android 11) ---
# 是否啟用「Pi 定時用 ADB 叫裝置刷新」。啟用時建議把 HTML_AUTO_REFRESH_SECONDS 設 0
REFRESH_VIA_ADB=false
ADB_REFRESH_SECONDS=300
ADB_BINARY=adb
# WiFi: 192.168.x.x:5555 (先在裝置 adb tcpip 5555 開過一次) / USB: 留空或填 serial
ADB_TARGET=
# 裝置瀏覽器開的看板網址。填 Pi 的區網 IP
DASHBOARD_URL=http://192.168.1.10:8000/
# 指定瀏覽器/kiosk App component, 例 de.ozerov.fully/.MainActivity;留空用系統預設
DEVICE_BROWSER_COMPONENT=
# e-ink full refresh 的廣播 action(HyRead 特有,接上裝置後確認);留空跳過
DEVICE_REFRESH_BROADCAST=

# --- 預留: Notion / 一般資料庫 (目前不啟用) ---
NOTION_TOKEN=
NOTION_DATABASE_ID=
DATABASE_URL=
