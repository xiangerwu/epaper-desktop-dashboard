{# 作息提醒:全部純黑白線條,kind 由 routine collector 決定。 #}
{% macro routine(kind, cls='') %}<svg class="ic {{ cls }}" viewBox="0 0 24 24">
{%- if kind == 'water' -%}
<path d="M12 2.5S6.5 9 6.5 14a5.5 5.5 0 0 0 11 0C17.5 9 12 2.5 12 2.5z"/><path d="M9 15.5a3 3 0 0 0 3 2.5"/>
{%- elif kind == 'breakfast' -%}
<path d="M3 18h18M6 14a6 6 0 0 1 12 0H6zM12 3v3M5.5 6.5l2 2M18.5 6.5l-2 2"/><circle cx="12" cy="14" r="1"/>
{%- elif kind == 'meal' -%}
<path d="M4 12h16a8 8 0 0 1-16 0zM7 20h10M8 8c0-1 1-1 1-2s-1-1-1-2M12 8c0-1 1-1 1-2s-1-1-1-2M16 8c0-1 1-1 1-2s-1-1-1-2"/>
{%- elif kind == 'moon' -%}
<path d="M19.5 15.5A8 8 0 0 1 8.5 4.5a8 8 0 1 0 11 11z"/><path d="M17.5 5.5h3M19 4v3"/>
{%- else -%}
<circle cx="12" cy="7" r="2"/><path d="M12 9v5M7 11l5 2 5-2M9 21l3-7 3 7M4 5h3M5.5 3.5v3M17 5h3M18.5 3.5v3"/>
{%- endif -%}
</svg>{% endmacro %}

{# 天氣:依狀態選圖 #}
{% macro weather(kind, cls='') %}<svg class="ic {{ cls }}" viewBox="0 0 24 24">
{%- if kind == 'sunny' -%}
<circle cx="12" cy="12" r="4.5"/><path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.6 4.6l1.8 1.8M17.6 17.6l1.8 1.8M19.4 4.6l-1.8 1.8M6.4 17.6l-1.8 1.8"/>
{%- elif kind == 'partly' -%}
<circle cx="8.8" cy="8.4" r="3.1"/><path d="M8.8 2.4v1.7M3.4 8.4H1.7M4.7 4.3l1.2 1.2M12.9 4.3l-1.2 1.2M2.9 12.6l1.2-.5"/><path d="M10 20a4.2 4.2 0 0 1-.2-8.4 5.4 5.4 0 0 1 10.35 1.4A3.5 3.5 0 0 1 19.2 20H10z" fill="#fff"/>
{%- elif kind == 'rain' -%}
<path d="M7.5 16a4.5 4.5 0 0 1-.3-9 6 6 0 0 1 11.5 1.5A3.75 3.75 0 0 1 18 16H7.5z"/><path d="M8 18.5l-1 2.5M12 18.5l-1 2.5M16 18.5l-1 2.5"/>
{%- else -%}
<path d="M7.5 19a4.5 4.5 0 0 1-.3-9 6 6 0 0 1 11.5 1.5A3.75 3.75 0 0 1 18 19H7.5z"/>
{%- endif -%}
</svg>{% endmacro %}
