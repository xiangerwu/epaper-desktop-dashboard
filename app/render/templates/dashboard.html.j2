{% import 'icons.html.j2' as ic %}<!doctype html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
{% if auto_refresh_seconds %}<meta http-equiv="refresh" content="{{ auto_refresh_seconds }}">{% endif %}
<style>
  /* e-ink 橫向佈局。尺寸用 vmin(=短邊/高)基準,橫直向皆一致;字級與框線已再縮小 */
  :root { --ink:#000; --mute:#555; --soft:#e2e2e2; }
  * { margin:0; padding:0; box-sizing:border-box; }
  html,body { height:100%; background:#fff; color:var(--ink);
    font-family:"Noto Sans CJK TC","Noto Sans TC","Microsoft JhengHei",sans-serif;
    -webkit-font-smoothing:none; }
  .page { height:100vh; padding:3vmin 3.2vmin; display:flex; flex-direction:column; gap:2.2vmin; }

  .ic { width:1em; height:1em; display:inline-block; vertical-align:-0.14em;
    fill:none; stroke:currentColor; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; }
  .ic-fill { fill:currentColor; stroke:none; }  /* 品牌標(claude/openai)官方 fill 路徑 */

  header { display:grid; grid-template-columns:1fr auto; align-items:center;
    border-bottom:0.4vmin solid var(--ink); padding-bottom:1.6vmin; }
  header .date { display:flex; align-items:baseline; gap:2.2vmin;
    font-size:4.4vmin; font-weight:800; }
  header .date .wk { font-size:3.4vmin; font-weight:800; }
  header .date .upd { font-size:2.5vmin; font-weight:700; color:var(--mute); }
  header .date .upd .ic { font-size:2.6vmin; margin-right:0.6vmin; color:var(--ink); }
  .refresh { justify-self:end; display:inline-flex; align-items:center; gap:1vmin;
    border:0.35vmin solid var(--ink); border-radius:5vmin; padding:0.9vmin 2.8vmin;
    font-size:2.7vmin; font-weight:800; color:var(--ink); text-decoration:none; }
  .refresh .ic { font-size:2.9vmin; }
  .refresh:active { background:var(--ink); color:#fff; }

  .main { flex:1; display:flex; gap:2.2vmin; min-height:0; }
  .col-left { flex:1; display:flex; flex-direction:column; gap:2.2vmin; }
  .col-right { flex:1.12; display:flex; flex-direction:column; gap:2.2vmin; min-width:0; }
  .ai-row { flex:0.85; display:flex; gap:2.2vmin; min-height:0; }
  .ai-row > .card { flex:1; }
  .col-right .cal { flex:1; }

  .card { border:0.4vmin solid var(--ink); border-radius:2vmin; padding:2.2vmin 2.6vmin; }
  .card h2 { font-size:2.8vmin; font-weight:800; margin-bottom:1.6vmin;
    display:flex; justify-content:space-between; align-items:center; }
  .card h2 .ttl { display:flex; align-items:center; gap:1.3vmin; }
  .card h2 .ttl .ic { font-size:3.3vmin; }
  .card h2 .age { font-size:2.2vmin; font-weight:500; color:var(--mute); }

  /* 天氣 */
  .weather .row { display:flex; align-items:center; gap:1.8vmin; }
  .weather .wicon { font-size:9.5vmin; line-height:0; }
  .weather .big { font-size:8.4vmin; font-weight:800; line-height:1; }
  .weather .vline { align-self:stretch; width:0.35vmin; background:var(--soft); margin:0.6vmin 0.6vmin; }
  .weather .meta { font-size:2.7vmin; color:var(--mute); line-height:1.5; }
  .weather .pill { display:inline-flex; align-items:center; gap:1vmin; margin-top:1.4vmin;
    white-space:nowrap; border:0.35vmin solid var(--ink); border-radius:5vmin; padding:0.7vmin 2vmin;
    font-size:2.4vmin; color:var(--ink); }
  .weather .pill .ic { font-size:2.7vmin; }

  /* AI 額度 */
  .ai-item:not(:last-child) { border-bottom:0.3vmin dashed var(--soft);
    padding-bottom:1.8vmin; margin-bottom:1.8vmin; }
  .ai-item .top { display:flex; justify-content:space-between; align-items:baseline; }
  .ai-item .lab { font-size:2.7vmin; font-weight:800; }
  .ai-item .pct { font-size:2.7vmin; font-weight:800; }
  .ai-item .bar { margin-top:1vmin; height:2.3vmin; border:0.35vmin solid var(--ink);
    border-radius:0.8vmin; overflow:hidden; }
  .ai-item .bar > span { display:block; height:100%; background:var(--ink); }
  .ai-item .sub { font-size:2.1vmin; color:var(--mute); margin-top:0.6vmin; }
  .ai-empty { font-size:2.5vmin; color:var(--mute); }

  /* 作息卡:上兩段略收、下段留給半身桌寵。 */
  .routine { flex:1; display:flex; flex-direction:column; min-height:0; }
  .routine-top { flex:1.6; display:flex; align-items:center; gap:2.4vmin; min-height:0;
    border-bottom:0.3vmin dashed var(--soft); padding-bottom:1.4vmin; }
  .routine .routine-icon { flex:none; font-size:6vmin; line-height:1; }
  .routine .routine-message { flex:1; min-width:0; font-size:2.5vmin; font-weight:800; line-height:1.35; }
  /* 中段番茄鐘:左側切換鈕 + 待機/運行兩態。純文字鈕、無圖示 */
  .pomodoro { flex:2.0; display:flex; align-items:center; gap:2.4vmin; min-height:0; }
  .pomo-btn { flex:none; border:0.35vmin solid var(--ink); border-radius:5vmin;
    padding:0.9vmin 3vmin; font:inherit; font-size:2.7vmin; font-weight:800;
    color:var(--ink); background:#fff; cursor:pointer; }
  .pomo-btn:active { background:var(--ink); color:#fff; }
  /* 待機:碼表 + 「番茄鐘 尚未啟動」 */
  .pomo-idle { flex:1; min-width:0; display:flex; align-items:center; justify-content:center;
    gap:1.2vmin; font-size:3.0vmin; font-weight:600; color:var(--mute); }
  .pomo-idle[hidden] { display:none; }
  .pomo-idle .ic { font-size:4vmin; color:var(--ink); }
  /* 運行:較大鬧鐘 + 右側(上 剩下時間、下 階段) */
  .pomo-run { flex:1; min-width:0; display:flex; align-items:center; justify-content:center; gap:2.2vmin; }
  .pomo-run[hidden] { display:none; }
  .pomo-run .pomo-alarm { flex:none; font-size:6vmin; color:var(--ink); }
  .pomo-run-text { min-width:0; text-align:left; }
  .pomo-remain { font-size:3.4vmin; font-weight:800; line-height:1.1; }
  .pomo-stage { font-size:2.1vmin; font-weight:500; color:var(--mute); margin-top:0.4vmin; }
  /* 桌寵只露上半身；完整 atlas 保持原尺寸，以 background-position 選幀。 */
  /* z 軸堆疊:寵物在下層(絕對定位、左下),對話框在上層撐滿整段,兩者 box 不互推 */
  .routine-extra { flex:6.4; min-height:0; --pet-k:2.15; border-top:0.3vmin dashed var(--soft);
    position:relative; overflow:visible; padding:0.4vmin 1.2vmin 0; }
  .pet-crop { position:absolute; left:0; bottom:0; z-index:0;
    width:calc(19vmin * var(--pet-k)); height:calc(15vmin * var(--pet-k));
    overflow:hidden; transform:translateY(2.15vmin); }
  .pet-sprite { width:calc(19vmin * var(--pet-k)); height:calc(20.58vmin * var(--pet-k));
    background:url('/pet/spritesheet.webp') no-repeat;
    background-size:calc(152vmin * var(--pet-k)) calc(185.22vmin * var(--pet-k));
    background-position:calc(var(--pet-col) * -19vmin * var(--pet-k)) calc(var(--pet-row) * -20.58vmin * var(--pet-k));
    transform:translate(calc(var(--pet-trim) * -0.09896vmin * var(--pet-k)), calc(0.5vmin * var(--pet-k))); }
  .pet-dialogue { position:absolute; right:0; top:0; bottom:0; width:52%; z-index:1;
    display:flex; align-items:center; font-size:2.8vmin; line-height:1.4; }

  /* Steam 狀態:左右兩欄 */
  .steam h2 .ttl .ic { font-size:3.8vmin; }  /* 官方 logo 放大更明顯 */
  .steam-cols { display:flex; gap:2.4vmin; }
  /* 左:類 RPG 狀態欄(簡潔直排,標籤—數值,列間虛線) */
  .steam-left { flex:0 0 40%; display:flex; flex-direction:column; justify-content:center;
    padding-right:2.6vmin; border-right:0.3vmin solid var(--soft); }
  .steam-stat { display:flex; justify-content:space-between; align-items:baseline; gap:1vmin;
    padding:1.1vmin 0; }
  .steam-stat:not(:last-child) { border-bottom:0.3vmin dashed var(--soft); }
  .steam-stat .k { font-size:2.7vmin; color:var(--mute); }
  .steam-stat .k.emoji { font-size:3.4vmin; line-height:1; }  /* 🏆/🏅 圖示比文字標籤略大 */
  .steam-stat .v { font-size:3.7vmin; font-weight:800; font-variant-numeric:tabular-nums; }
  .steam-stat .v small { font-size:2.3vmin; font-weight:600; color:var(--mute); }
  /* 右:上遊戲 / 下成就進度 */
  .steam-right { flex:1; min-width:0; display:flex; flex-direction:column; gap:1.4vmin; }
  .steam-seg .lab { font-size:2.1vmin; color:var(--mute); font-weight:700; margin-bottom:0.4vmin; }
  .steam-seg .game { font-size:2.8vmin; font-weight:800; line-height:1.25;
    overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .steam-seg .hrs { font-size:2.3vmin; color:var(--mute); font-variant-numeric:tabular-nums; }
  .steam-seg .hrs b { color:var(--ink); font-weight:800; }
  .steam-right .divider { border-top:0.3vmin solid var(--soft); }
  .steam-prog .bar { margin-top:0.8vmin; height:2.3vmin; border:0.35vmin solid var(--ink);
    border-radius:0.8vmin; overflow:hidden; }
  .steam-prog .bar > span { display:block; height:100%; background:var(--ink); }
  .steam-prog .count { font-size:2.3vmin; font-weight:800; font-variant-numeric:tabular-nums;
    margin-top:0.6vmin; }
  .steam-prog .count small { font-weight:600; color:var(--mute); }
  .steam-prog .latest { font-size:2.1vmin; color:var(--mute); margin-top:0.2vmin;
    overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }

</style>
</head>
<body>
<div class="page">
  <header>
    <div class="date">{{ generated_at.split('  ')[0] }}<span class="wk">星期{{ weekday }}</span><span class="upd">{{ ic.clock() }}頁面更新於 {{ generated_at.split('  ')[1] }}</span></div>
    <a class="refresh" href="/refresh">{{ ic.refresh() }} 立即刷新</a>
  </header>

  <div class="main">
    <div class="col-left">
      <section class="card weather">
        <h2><span class="ttl">天氣 {% if weather %}· {{ weather.location }}{% endif %}</span><span class="age">{{ weather_age }}</span></h2>
        {% if weather %}
        <div class="row">
          <span class="wicon">{{ ic.weather(weather_icon) }}</span>
          <div class="big">{{ weather.max_t }}°</div>
          <div class="vline"></div>
          <div class="meta">
            {{ weather.desc }}<br>
            低 {{ weather.min_t }}° · 降雨 {{ weather['pop'] }}%
            {% if air and air.aqi is not none %}<br><span class="pill">{{ ic.leaf() }} 空氣{{ air.status }} · AQI {{ air.aqi }}</span>
            {% elif weather.comfort %}<br><span class="pill">{{ ic.leaf() }} {{ weather.comfort }}</span>{% endif %}
          </div>
        </div>
        {% else %}
        <div class="meta">尚無天氣資料</div>
        {% endif %}
      </section>

      <section class="card routine">
        <div class="routine-top">
          <div class="routine-icon">{{ routine.emoji }}</div>
          <div class="routine-message">{{ routine.message }}</div>
        </div>
        <div class="pomodoro">
          <button type="button" class="pomo-btn" id="pomoBtn">開始</button>
          <div class="pomo-idle" id="pomoIdle">{{ ic.stopwatch() }}<span>番茄鐘 尚未啟動</span></div>
          <div class="pomo-run" id="pomoRun" hidden>
            {{ ic.alarm('pomo-alarm') }}
            <div class="pomo-run-text">
              <div class="pomo-remain" id="pomoRemain"></div>
              <div class="pomo-stage" id="pomoStage"></div>
            </div>
          </div>
        </div>
        <div class="routine-extra">
          <div class="pet-crop" aria-hidden="true"><div class="pet-sprite" id="petSprite"></div></div>
          <div class="pet-dialogue" id="petDialogue" aria-live="polite"></div>
        </div>
      </section>
    </div>

    <div class="col-right">
      <div class="ai-row">
      {% for col in ai_columns %}
      <section class="card">
        <h2><span class="ttl">{% if col.icon == 'claude' %}{{ ic.claude() }}{% else %}{{ ic.openai() }}{% endif %} {{ col.name }}</span><span class="age">{{ col.age }}</span></h2>
        {% for q in col.lines %}
        <div class="ai-item">
          <div class="top"><span class="lab">{{ q.label }}</span><span class="pct">{{ q.pct }}%</span></div>
          <div class="bar"><span style="width: {{ q.pct }}%"></span></div>
          {% if q.detail %}<div class="sub">{{ q.detail }}</div>{% endif %}
        </div>
        {% else %}
        <div class="ai-empty">{{ col.empty }}</div>
        {% endfor %}
      </section>
      {% endfor %}
      </div>

      <section class="card cal steam">
        <h2><span class="ttl">{{ ic.steam() }} Steam 狀態</span><span class="age">{{ steam.age }}</span></h2>
        <div class="steam-cols">
          <div class="steam-left">
            {% if steam.summary and steam.summary.level is not none %}
            <div class="steam-stat"><span class="k">レベル</span><span class="v">{{ steam.summary.level }}</span></div>
            {% endif %}
            {% if steam.summary and steam.summary.total_achievements is not none %}
            <div class="steam-stat"><span class="k emoji">🏆</span><span class="v">{{ "{:,}".format(steam.summary.total_achievements) }}</span></div>
            {% endif %}
            {% if steam.summary and steam.summary.badge_count is not none %}
            <div class="steam-stat"><span class="k emoji">🏅</span><span class="v">{{ steam.summary.badge_count }}</span></div>
            {% endif %}
            {% if steam.summary and steam.summary.hours_2weeks_total is not none %}
            <div class="steam-stat"><span class="k">近2週</span><span class="v">{{ "%.1f"|format(steam.summary.hours_2weeks_total) }} <small>h</small></span></div>
            {% endif %}
          </div>

          <div class="steam-right">
            {% if steam.top %}
            <div class="steam-seg">
              <div class="lab">{{ ic.gamepad() }} 最近遊玩最多</div>
              <div class="game">{{ steam.top.name }}</div>
              <div class="hrs">兩週 <b>{{ "%.1f"|format(steam.top.hours_2weeks) }}</b> · 總 {{ "%.0f"|format(steam.top.hours_total) }} h</div>
            </div>
            <div class="divider"></div>
            <div class="steam-seg steam-prog">
              <div class="lab">{{ ic.trophy() }} 成就進度</div>
              {% if steam.top.ach %}
              <div class="bar"><span style="width: {{ steam.top.ach.pct }}%"></span></div>
              <div class="count">{{ steam.top.ach.unlocked }} / {{ steam.top.ach.total }} <small>· {{ steam.top.ach.pct }}%</small></div>
              {% if steam.top.latest %}
              <div class="latest">最新:{{ steam.top.latest.name }}{% if steam.top.latest.rarity_pct is not none %} · 全球 {{ steam.top.latest.rarity_pct }}%{% endif %}</div>
              {% endif %}
              {% else %}
              <div class="count"><small>此遊戲無成就</small></div>
              {% endif %}
            </div>
            {% else %}
            <div class="ai-empty">近期無遊玩紀錄</div>
            {% endif %}
          </div>
        </div>
      </section>
    </div>
  </div>

</div>

<script>
/* 番茄鐘:狀態存電子閱讀器本機 localStorage,伺服器維持無狀態。
   一循環 50 分鐘 = 5 段 × 10 分:第 1-4 段工作,第 5 段喝水休息;滿 50 分回待機。
   只在每段到點切換一次提醒文字(e-ink 友善)。文案/時間改下面常數即可。 */
(function () {
  var SEG_SEC = 600;      // 每段秒數(10 分)
  var SEG_COUNT = 5;      // 一循環段數(50 分)
  var LS_KEY = "pomo_start";
  var MAIN = ["專注工作中", "專注工作中", "專注工作中", "專注工作中", "喝水休息"];
  var btn = document.getElementById("pomoBtn");
  var idleEl = document.getElementById("pomoIdle");
  var runEl = document.getElementById("pomoRun");
  var remainEl = document.getElementById("pomoRemain");
  var stageEl = document.getElementById("pomoStage");
  var petEl = document.getElementById("petSprite");
  var dialogueEl = document.getElementById("petDialogue");
  var PET_DIALOGUES = {{ pet_dialogues | tojson }};
  var timer = null;
  var petState = "";
  var petFrame = 0;
  var PET_STATES = {
    idle:    { row: 0, frames: [0, 1, 2], trim: [34, 34, 31] },
    greeting:{ row: 3, frames: [0, 1, 2, 3], trim: [30, 28, 29, 29] },
    break:   { row: 4, frames: [0, 1, 2, 3, 4], trim: [18, 29, 24, 30, 30] },
    waiting: { row: 6, frames: [0, 1, 2], trim: [38, 38, 39] },
    focus:   { row: 7, frames: [0, 1, 2], trim: [33, 33, 34] }
  };

  function timePetState() {
    var now = new Date();
    var minute = now.getHours() * 60 + now.getMinutes();
    if (minute >= 420 && minute < 510) return "greeting"; // 07:00–08:29
    if ((minute >= 510 && minute < 750) ||
        (minute >= 840 && minute < 1110) ||
        (minute >= 1170 && minute < 1260)) return "waiting";
    return "idle";
  }

  function paintPet() {
    var state = PET_STATES[petState];
    petEl.style.setProperty("--pet-row", state.row);
    petEl.style.setProperty("--pet-col", state.frames[petFrame]);
    petEl.style.setProperty("--pet-trim", state.trim[petFrame]);
  }

  function paintDialogue() {
    var lines = PET_DIALOGUES[petState] || [];
    dialogueEl.textContent = lines.length ? lines[Math.floor(Math.random() * lines.length)] : "";
  }

  function setPet(state) {
    if (state !== petState) { petState = state; petFrame = 0; paintDialogue(); }
    paintPet();
  }

  function advancePet() {
    if (!localStorage.getItem(LS_KEY)) setPet(timePetState());
    var frames = PET_STATES[petState].frames;
    petFrame = (petFrame + 1) % frames.length;
    paintPet();
  }

  function showIdle() {
    btn.textContent = "開始"; idleEl.hidden = false; runEl.hidden = true;
    setPet(timePetState());
  }

  function idle() { localStorage.removeItem(LS_KEY); showIdle(); }

  function render() {
    if (timer) { clearTimeout(timer); timer = null; }
    var raw = localStorage.getItem(LS_KEY);
    if (!raw) { showIdle(); return; }
    var elapsed = (Date.now() - parseInt(raw, 10)) / 1000;
    if (!(elapsed >= 0) || elapsed >= SEG_SEC * SEG_COUNT) { idle(); return; }
    var seg = Math.floor(elapsed / SEG_SEC);
    btn.textContent = "停止";
    idleEl.hidden = true;
    runEl.hidden = false;
    // 距整個循環結束的剩餘,依段量化(50/40/30/20/10),只在到點才變。
    remainEl.textContent = "剩 " + (SEG_COUNT - seg) * (SEG_SEC / 60) + " 分";
    stageEl.textContent = MAIN[seg] + " · 第 " + (seg + 1) + " 段 / 共 " + SEG_COUNT + " 段";
    setPet(seg < 4 ? "focus" : "break");
    var next = (seg + 1) * SEG_SEC;   // 下一段邊界(到 50 分則回待機)
    timer = setTimeout(render, (next - elapsed) * 1000 + 500);
  }

  btn.addEventListener("click", function () {
    if (localStorage.getItem(LS_KEY)) { idle(); }
    else { localStorage.setItem(LS_KEY, String(Date.now())); }
    render();
  });

  render();
  setInterval(advancePet, 60000); // e-ink:每分鐘換一幀，不做連續動畫。
})();
</script>
</body>
</html>
